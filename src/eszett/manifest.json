{
    "browser_specific_settings": {
        "gecko": {
            "data_collection_permissions": {
                "required": [
                    "none"
                ]
            },
            "id": "eszett@johannes-programming.online"
        },
        "gecko_android": {
            "strict_min_version": "120.0"
        }
    },
    "content_scripts": [
        {
            "js": [
                "content.js"
            ],
            "matches": [
                "<all_urls>"
            ],
            "run_at": "document_idle"
        }
    ],
    "description": "This extension replaces the german letter eszett with two s everywhere.",
    "icons": {
        "16": "icons/icon-16.png",
        "48": "icons/icon-48.png",
        "128": "icons/icon-128.png"
    },
    "manifest_version": 3,
    "name": "eszett",
    "version": "1.0.3"
}
